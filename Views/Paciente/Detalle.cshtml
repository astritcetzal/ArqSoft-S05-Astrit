@model Citas_App.Domain.Models.Paciente
<h1>@Model.Nombre @Model.Apellido</h1>
<p><strong>Email:</strong> @Model.Email</p>
<p><strong>Teléfono:</strong> @Model.Telefono</p>
<hr />
<a asp-action="Index" class="btn-agregar-cita">← Volver a la lista</a>
<hr />
<a asp-controller="Cita" class="btn-agregar-cita" asp-action="PorPaciente" asp-route-pacienteId="@Model.Id">Ver sus citas</a>

