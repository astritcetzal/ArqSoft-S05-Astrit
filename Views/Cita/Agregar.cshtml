@model Citas_App.Domain.Models.Cita

<div class="contenedor-formulario">
    <h1>Agregar cita</h1>
    <form asp-action="Agregar" method="post" enctype="multipart/form-data">
        
        <div class="cita-input">
            <label>Paciente</label>
            <select asp-for="PacienteId">
                <option value="">-- Selecciona un paciente --</option>
        
                @foreach (var p in ViewBag.Pacientes)
                {
                    <option value="@p.Id">@p.Nombre @p.Apellido</option>
                }
            </select>
        </div>
        <div class="cita-input">
            <label>Médico</label>
            <select asp-for="MedicoId">
                <option value="">-- Selecciona un médico --</option>
        
                @foreach (var m in ViewBag.Medicos)
                {
                    <option value="@m.Id">@m.Nombre @m.Apellido</option>
                }
            </select>
        </div>
        <div class="cita-input">
            <label>Fecha</label>
            <input asp-for="Fecha" type="date" />
        </div>
        <div class="cita-input">
            <label>Hora</label>
            <input asp-for="Hora" type="time" />
        </div>
        <div class="cita-input">
            <label>Motivo</label>
            <textarea asp-for="Motivo"> </textarea>
        </div>
        <div class="cita-input">
            <label>Estado de la cita</label>
            <select asp-for="Estado">
                <option value="Pendiente">Pendiente</option>
                <option value="Confirmada">Confirmada</option>
                <option value="Cancelada">Cancelada</option>
            </select>
        </div>
        <hr/>
            <button type="submit" class="btn-guardar">Guardar cita</button>

        </form>

        <hr />
        <a asp-action="Index" class="link-cancelar">&larr; Cancelar</a>

    </div>
